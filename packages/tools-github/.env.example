# Optional GitHub token used by @helmsman/tools-github.
# Leave empty if you only need public-repo reads.
# Required for:
# - private repositories
# - code search endpoint
# - higher API rate limits
# Create a token here:
# - Fine-grained PAT (recommended): https://github.com/settings/personal-access-tokens/new
# - Classic PAT: https://github.com/settings/tokens
# Minimum practical scopes:
# - Public repos: public_repo
# - Private repos: repo
# - Discussions read: read:discussion
GITHUB_TOKEN=

# Optional API base URL.
# Keep empty for github.com (default is https://api.github.com).
# Set only when using GitHub Enterprise Server, for example:
# https://github.your-company.com/api/v3
GITHUB_API_BASE_URL=
