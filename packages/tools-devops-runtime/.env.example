# Docker daemon endpoint used by dockerode.
# Linux/macOS default:
DOCKER_SOCKET_PATH=/var/run/docker.sock
# Windows Docker Desktop default (use this on Windows):
# DOCKER_SOCKET_PATH=npipe:////./pipe/docker_engine

# Runtime container image name used for task execution.
# This is a LOCAL image tag by default (not Docker Hub).
# Build it locally with:
# docker build -f packages/tools-devops-runtime/docker/Dockerfile.runtime -t helmsman-runtime:latest packages/tools-devops-runtime/docker
HELMSMAN_RUNTIME_IMAGE=helmsman-runtime:latest

# Safety gate for networked task runs with egress allowlist.
# false = suitable for local unit tests/non-networked development.
# true = require real egress enforcement path before networked execution.
HELMSMAN_ENFORCE_EGRESS_ALLOWLIST=false

# Default hard timeout per container task in milliseconds.
CONTAINER_DEFAULT_TIMEOUT_MS=300000

# Default memory limit per container in bytes (268435456 = 256MB).
CONTAINER_DEFAULT_MEMORY_BYTES=268435456

# Default CPU quota as fraction of 1 core (0.5 = 50% of one core).
CONTAINER_DEFAULT_CPU_QUOTA=0.5

# Max persisted workspace volume size in bytes (524288000 = 500MB).
CONTAINER_MAX_WORKSPACE_BYTES=524288000
