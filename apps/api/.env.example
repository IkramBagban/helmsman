PORT=3000
NODE_ENV=development
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-secret
LLM_PROVIDER=gemini
REDIS_URL=

# Optional: override model defaults
# TELEGRAM_LLM_MODEL=gemini-2.0-flash

# Required when LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Required when LLM_PROVIDER=gemini (any one is accepted)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_BASE_URL=

# Optional: GitHub tools (recommended for authenticated access and higher rate limits)
# GITHUB_TOKEN=
# GITHUB_API_BASE_URL=

# Optional: DevOps runtime tools (Docker-backed execution sandbox)
# Runtime image name/tag used by tools-devops-runtime
# HELMSMAN_RUNTIME_IMAGE=helmsman-runtime:latest
# Docker engine socket/pipe path
# Linux/macOS: DOCKER_SOCKET_PATH=/var/run/docker.sock
# Windows Docker Desktop: DOCKER_SOCKET_PATH=//./pipe/docker_engine
# DOCKER_SOCKET_PATH=/var/run/docker.sock
# Default per-task timeout (ms)
# CONTAINER_DEFAULT_TIMEOUT_MS=300000
# Default memory limit in bytes (268435456 = 256MB)
# CONTAINER_DEFAULT_MEMORY_BYTES=268435456
# Default CPU quota as cores (0.5 = half core)
# CONTAINER_DEFAULT_CPU_QUOTA=0.5
# Keep false unless strict egress allowlist enforcement is configured
# HELMSMAN_ENFORCE_EGRESS_ALLOWLIST=false
